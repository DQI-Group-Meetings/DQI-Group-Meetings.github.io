Cell["We first define the symplectic form:", "Text",
 CellChangeTimes->{{3.941451904276731*^9, 
  3.941451910717362*^9}},ExpressionUUID->"b58f0b89-7832-4c69-84fc-\
f8f7d5a99949"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"J", "[", "n_", "]"}], ":=", 
   RowBox[{"KroneckerProduct", "[", 
    RowBox[{
     RowBox[{"IdentityMatrix", "[", 
      RowBox[{"n", "/", "2"}], "]"}], ",", 
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"0", "1"},
        {
         RowBox[{"-", "1"}], "0"}
       }], "\[NoBreak]", ")"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"J", "[", "4", "]"}], "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"Eigenvalues", "@", 
  RowBox[{"(", 
   RowBox[{"\[ImaginaryI]", " ", "%"}], ")"}]}]}], "Input",
 CellFrame->True,
