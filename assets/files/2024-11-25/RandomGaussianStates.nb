Cell[TextData[{
 StyleBox["Validity of Gaussian states:",
  FontWeight->"Bold"],
 " \n\nA valid CM should obey\n\nS + i ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "6270ee74-bee3-47b1-b775-f1b7bda3991d"],
 " \[GreaterEqual] 0,\n\nwhich we can express in terms of its minimum \
eigenvalue. Namely, it should be larger than or equal than zero."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellFrameColor->RGBColor[0, 0.67, 0],
 CellChangeTimes->{
  3.896157307770092*^9, {3.8962431518956203`*^9, 3.896243165248736*^9}, {
   3.8962432007660027`*^9, 3.896243215679708*^9}, 3.89624387579119*^9, 
   3.8962479341938753`*^9, 3.896349890244479*^9, {3.896431738204154*^9, 
   3.896431793731579*^9}, {3.896432175643674*^9, 3.896432224386896*^9}, {
   3.898591709469429*^9, 3.8985917097904797`*^9}, {3.89859199556601*^9, 
   3.898591999597328*^9}, {3.898675292731111*^9, 3.898675304034505*^9}, {
