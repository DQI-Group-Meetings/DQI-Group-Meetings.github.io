Cell[CellGroupData[{

Cell["Eigenvalues of the RQCM ensemble", "Subsection",
 CellChangeTimes->{{3.9414518716916122`*^9, 3.941451895828915*^9}, {
  3.9414527654500313`*^9, 
  3.941452772313993*^9}},ExpressionUUID->"1de29b03-f2b7-4f18-bc15-\
1c5763019143"],

Cell["For convenience we define the \[OpenCurlyDoubleQuote]numerical Free \
Convolution\[CloseCurlyDoubleQuote]:", "Text",
 CellChangeTimes->{{3.941452775521484*^9, 3.9414527821699467`*^9}, {
  3.941526617114812*^9, 
  3.94152661945164*^9}},ExpressionUUID->"0232a6fa-60a8-496b-9a32-\
871e6e0ab609"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"A_", " ", "\:229e", " ", "B_"}], ":=", 
   RowBox[{"Eigenvalues", "[", 
    RowBox[{"A", "+", "B"}], "]"}]}], ";"}]], "Input",
 CellFrame->True,
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.927963244517919*^9, 3.9279632988279943`*^9}, {
   3.9279641774191113`*^9, 3.927964184003414*^9}, 3.927964322291379*^9, 
   3.941385634649486*^9, 3.941386298485345*^9, {3.9413863298356*^9, 
   3.941386360134748*^9}, {3.941387164442535*^9, 3.9413871664342003`*^9}, {
   3.9413882394969797`*^9, 3.9413882595636873`*^9}, {3.941388572438921*^9, 
   3.941388593973333*^9}, {3.9413888565763197`*^9, 3.941388878571753*^9}, 
   3.941389398455037*^9, {3.941390390359954*^9, 3.941390408613124*^9}},
 Background->GrayLevel[0.95],
 CellLabel->"In[23]:=",ExpressionUUID->"738fd4dd-c84b-4a32-b390-fbda1883c590"],

Cell["\<\
In order to find the distribution of eigenvalues in the QRCM ensemble, we \
compute the convolution (numerically) of three different GOE matrices with \
the symplectic form -- changing \[Sigma]:\
\>", "Text",
 CellChangeTimes->{{3.9414528877464333`*^9, 3.941452943355576*^9}, {
   3.941521339606557*^9, 3.941521343244648*^9}, 
   3.941526609322678*^9},ExpressionUUID->"e6dc1a49-2818-4443-ac66-\
491da1a1cd5e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", " ", "=", " ", "1000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["\[Mu]", "\[Sigma]"], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"G", "[", 
       RowBox[{"n", ",", "#"}], "]"}], "\:229e", " ", 
      RowBox[{"(", 
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"J", "[", 
         RowBox[{"2", "n"}], "]"}]}], ")"}]}], "&"}], "/@", 
    RowBox[{"{", 
     RowBox[{"2", ",", "1", ",", "0.5"}], "}"}]}]}], ";"}]}], "Input",
 CellFrame->True,
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.927963244517919*^9, 3.9279632988279943`*^9}, {
   3.9279641774191113`*^9, 3.927964184003414*^9}, 3.927964322291379*^9, 
   3.941385634649486*^9, 3.941386298485345*^9, {3.9413863298356*^9, 
   3.941386360134748*^9}, {3.941387164442535*^9, 3.9413871664342003`*^9}, {
   3.9413882394969797`*^9, 3.9413882595636873`*^9}, {3.941388572438921*^9, 
   3.941388593973333*^9}, {3.9413888565763197`*^9, 3.941388878571753*^9}, 
   3.941389398455037*^9, {3.94139042306199*^9, 3.941390435196216*^9}, {
   3.9413904978425627`*^9, 3.941390497886609*^9}, {3.941390975122294*^9, 
   3.941391087745839*^9}, {3.941391602007557*^9, 3.9413916586917667`*^9}, {
   3.9413917264705067`*^9, 3.941391733285849*^9}, {3.9413917691100616`*^9, 
   3.94139177597466*^9}, 3.9413918469954443`*^9, {3.94139197593519*^9, 
   3.9413919762015533`*^9}},
 Background->GrayLevel[0.95],
 CellLabel->"In[24]:=",ExpressionUUID->"05e55d16-834b-4cb9-9ac6-f6fe19d785cc"],

Cell["Analytically, the distribution looks like:", "Text",
 CellChangeTimes->{{3.941452952594872*^9, 
  3.94145295709079*^9}},ExpressionUUID->"8a0c2948-0dc7-41bd-9dd2-\
82d3ffb3729d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", "\[Sigma]_", "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       FractionBox["\[Sigma]", "4"], 
       RowBox[{"(", 
        RowBox[{
         SqrtBox[
          RowBox[{"8", "+", 
           SuperscriptBox["\[Sigma]", "2"]}]], "-", "\[Sigma]"}], ")"}]}]}], 
     ")"}], 
    SqrtBox[
     RowBox[{"1", "+", 
      RowBox[{
       FractionBox["\[Sigma]", "2"], 
       RowBox[{"(", 
        RowBox[{
         SqrtBox[
          RowBox[{"8", "+", 
           SuperscriptBox["\[Sigma]", "2"]}]], "+", "\[Sigma]"}], 
        ")"}]}]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DSc", "[", 
    RowBox[{"x_", ",", "\[Sigma]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       SqrtBox[
        RowBox[{
         RowBox[{"4", 
          SuperscriptBox["\[Sigma]", "2"]}], "-", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"x", "-", "m"}], ")"}], "2"]}]], 
       RowBox[{"2", "\[Pi]", " ", 
        SuperscriptBox["\[Sigma]", "2"]}]], 
      RowBox[{"Boole", "[", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"x", "-", "m"}], "]"}], "<", 
        RowBox[{"2", "\[Sigma]"}]}], "]"}]}], ")"}], "/.", 
    RowBox[{"(", 
     RowBox[{"m", "->", " ", 
      RowBox[{"R", "[", "\[Sigma]", "]"}]}], ")"}]}]}], ";"}]}], "Input",
 CellFrame->True,
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.927963244517919*^9, 3.9279632988279943`*^9}, {
   3.9279641774191113`*^9, 3.927964184003414*^9}, 3.927964322291379*^9, 
   3.941385634649486*^9, 3.941386298485345*^9, {3.9413863298356*^9, 
   3.941386360134748*^9}, {3.941387164442535*^9, 3.9413871664342003`*^9}, {
   3.9413882394969797`*^9, 3.9413882595636873`*^9}, {3.941388572438921*^9, 
   3.941388593973333*^9}, {3.9413888565763197`*^9, 3.941388878571753*^9}, 
   3.941389398455037*^9, {3.94139042306199*^9, 3.941390435196216*^9}, {
   3.9413904978425627`*^9, 3.941390497886609*^9}, {3.941390975122294*^9, 
   3.941391087745839*^9}, {3.941391602007557*^9, 3.9413916586917667`*^9}, {
   3.9413917264705067`*^9, 3.941391733285849*^9}, {3.9413917691100616`*^9, 
   3.94139177597466*^9}, 3.9413918469954443`*^9, {3.94139197593519*^9, 
   3.9413919762015533`*^9}, {3.9413926489974937`*^9, 3.941392677599703*^9}, {
   3.9413927779074993`*^9, 3.941392780511853*^9}, {3.941393253156582*^9, 
   3.9413932688663387`*^9}, 3.9414768775641813`*^9},
 Background->GrayLevel[0.95],
 CellLabel->"In[57]:=",ExpressionUUID->"0e893ab4-58df-4801-9b76-8abeff9525f9"],

