Cell[TextData[{
 StyleBox["Measure of the QRCMs:",
  FontWeight->"Bold"],
 " \n\nSince the symplectic form has just eigenvalues +1 or -1, it works as a \
\[OpenCurlyDoubleQuote]Bernoulli distribution\[CloseCurlyDoubleQuote], and \
the result above corresponds to the convolution:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox["\[Delta]", "1"]}], " ", "+", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SubscriptBox["\[Delta]", 
       RowBox[{"-", "1"}]]}]}], ")"}], TraditionalForm]],ExpressionUUID->
  "55dffd6a-b581-4595-8b86-62c86bc10ab1"],
 " \:229e ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["SC", "\[Sigma]"], TraditionalForm]],ExpressionUUID->
  "a32f942f-6a75-4f3b-b507-2b90ea670c90"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["SC", "\[Sigma]"], TraditionalForm]],ExpressionUUID->
  "abcd8c8e-d690-4afc-b614-f8cb6412c7ca"],
 " is the semicircular distribution ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["SC", "\[Sigma]"], TraditionalForm]],ExpressionUUID->
  "b9f0c4f4-6ce7-4fe5-b9cf-d89a8dee8cab"],
 " := ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SqrtBox[
      RowBox[{
       RowBox[{"4", 
        SuperscriptBox["\[Sigma]", "2"]}], "-", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"x", "-", "m"}], ")"}], "2"]}]], 
     RowBox[{"2", "\[Pi]", " ", 
      SuperscriptBox["\[Sigma]", "2"]}]], 
    SubscriptBox["1", 
     RowBox[{"|", 
      RowBox[{"x", "<", 
       RowBox[{"2", "\[Sigma]"}]}], "|"}]], 
    RowBox[{"(", "x", ")"}], "dx"}], TraditionalForm]],ExpressionUUID->
  "905ce1f7-bd9a-45d6-ae09-3e3ef315d50a"],
 ".\n\nThe analytical result can be obtained by using the Stieltjes\
\[CloseCurlyQuote] inversion formula from the R-transform obtained from this \
problem:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[ScriptCapitalR]", 
      SubscriptBox["\[Mu]", "\[Sigma]"]], "(", "z", ")"}], " ", "=", " ", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalR]", "Bernoulli"], "(", "z", ")"}]}], 
   TraditionalForm]],ExpressionUUID->"b227d8b9-d0b0-4e7a-af64-ec73657ab9a0"],
 " + ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalR]", 
     SubscriptBox["SC", "\[Sigma]"]], "(", "z", ")"}], TraditionalForm]],
  ExpressionUUID->"0da1acae-e9bc-4c90-a20c-18cc099055cc"],
 " = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SqrtBox[
      RowBox[{"1", " ", "+", " ", 
       RowBox[{"4", 
        SuperscriptBox["z", "2"]}]}]], " ", "-", "1"}], 
    RowBox[{"2", "z"}]], TraditionalForm]],ExpressionUUID->
  "9c163643-dae6-4228-84a7-41a3ab76fe6c"],
 "+ \[Sigma] z.\n\nwhich lead us to some complicated cubic roots."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellFrameColor->RGBColor[0, 0.67, 0],
 CellChangeTimes->{
  3.896157307770092*^9, {3.8962431518956203`*^9, 3.896243165248736*^9}, {
   3.8962432007660027`*^9, 3.896243215679708*^9}, 3.89624387579119*^9, 
   3.8962479341938753`*^9, 3.896349890244479*^9, {3.896431738204154*^9, 
   3.896431793731579*^9}, {3.896432175643674*^9, 3.896432224386896*^9}, {
   3.898591709469429*^9, 3.8985917097904797`*^9}, {3.89859199556601*^9, 
   3.898591999597328*^9}, {3.898675292731111*^9, 3.898675304034505*^9}, {
   3.898676091306068*^9, 3.898676097371314*^9}, 3.906796741677164*^9, {
   3.941452350484767*^9, 3.941452439319812*^9}, {3.94145363320478*^9, 
   3.94145368303008*^9}, {3.941453733020797*^9, 3.941453799978505*^9}, {
   3.941453851898497*^9, 3.941454052044414*^9}},
 Background->RGBColor[
  0.88, 1, 0.88],ExpressionUUID->"76288a59-a40f-4eeb-a313-cb79e7b7df0e"],

Cell[TextData[{
 "Very interestingly, we can see that we have \
\[OpenCurlyDoubleQuote]phase-transition\[CloseCurlyDoubleQuote] on the \
support of the matrices of this example at \[Sigma] = 1. One has:\n\n\
\[Bullet] Support on two intervals for \[Sigma] > 1\n\[Bullet] Support on a \
single interval for  \[Sigma] < 1\n\nNote that a similar convolution with CUE \
instead of GOE matrices leads to a very different distribution. Namely, the \
arcsine distribution:\n\n",
 Cell[BoxData[
  FormBox[
   GraphicsBox[{{
