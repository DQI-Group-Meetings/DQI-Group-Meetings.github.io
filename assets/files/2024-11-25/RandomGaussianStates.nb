Cell[TextData[{
 "And GOE matrices with variance ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Sigma]", "2"], TraditionalForm]],ExpressionUUID->
  "49a94328-5407-4700-9b96-8a2e7938513a"],
 ":"
}], "Text",
 CellChangeTimes->{{3.941451914122863*^9, 
  3.9414519338446407`*^9}},ExpressionUUID->"9a1b6b48-303b-4f28-8fbd-\
fd0a9e034cd2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "GOE", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"G", "[", 
    RowBox[{"n_", ",", 
     RowBox[{"\[Sigma]_", ":", "1"}]}], "]"}], ":=", 
   RowBox[{
    FractionBox["1", 
     SqrtBox["n"]], 
    RowBox[{"RandomVariate", "@", 
     RowBox[{"GaussianOrthogonalMatrixDistribution", "[", 
      RowBox[{"\[Sigma]", ",", " ", 
       RowBox[{"2", "n"}]}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G", "[", "1", "]"}], "//", "MatrixForm"}]}], "Input",
 CellFrame->True,
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.927963244517919*^9, 3.9279632988279943`*^9}, {
