Cell[TextData[{
 StyleBox["Generating Random Gaussian States",
  FontSize->14,
  FontWeight->"Bold"],
 StyleBox["\n\nThe ensemble of Random Quantum Covariance Matrices (RQCM), \
denoted by RQCM(2n, \[Sigma]), has elements:\n\n",
  FontSize->14],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "G"], " ", ":=", " ", 
    RowBox[{"G", " ", "+", " ", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Lambda]", "max"], "[", 
       RowBox[{
        RowBox[{"i", " ", 
         SubscriptBox["J", 
          RowBox[{"2", "n"}]]}], " ", "-", " ", "G"}], "]"}], 
      SubscriptBox["I", 
       RowBox[{"2", "n"}]]}]}]}], TraditionalForm]],
  FontSize->14,ExpressionUUID->"02a715d4-eb7b-40e0-a913-1d20e05b132b"],
 StyleBox["\n \n There G is drawn from the GOE ensemble G \[Element] GOE(2n, \
\[Sigma]) and ",
  FontSize->14],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["J", 
     RowBox[{"2", "n"}]], " "}], TraditionalForm]],
  FontSize->14,ExpressionUUID->"f297799d-b720-49c6-a003-705bb88bb02a"],
 StyleBox[" is the symplectic form defined above.",
  FontSize->14]
}], "Text",
 CellFrame->{{0.5, 3}, {3, 0.5}},
 CellFrameColor->RGBColor[0.333333, 0.666667, 1],
 CellChangeTimes->{{3.856491103156457*^9, 3.856491143992709*^9}, {
   3.887975987005028*^9, 3.887976006741371*^9}, {3.895202769385974*^9, 
   3.8952028245539722`*^9}, {3.895214150168776*^9, 3.8952141501688023`*^9}, {
   3.8953183568127613`*^9, 3.895318434174921*^9}, {3.896261377697947*^9, 
   3.8962616505220013`*^9}, {3.896348175574924*^9, 3.896348291094212*^9}, {
   3.8963483289321527`*^9, 3.8963485027024107`*^9}, {3.8963485424628143`*^9, 
   3.8963485778942347`*^9}, {3.89634863539023*^9, 3.896348738846053*^9}, 
   3.8963489724061403`*^9, {3.896432246984685*^9, 3.896432348075972*^9}, {
   3.898591634844574*^9, 3.898591666741028*^9}, {3.8985917886695433`*^9, 
   3.898591788921177*^9}, 3.898675264014736*^9, {3.898761488507275*^9, 
   3.898761505883017*^9}, {3.906796695940009*^9, 3.906796734750552*^9}, {
   3.9414520127183523`*^9, 3.941452043437748*^9}, {3.941452088925693*^9, 
   3.941452224262775*^9}},
 Background->RGBColor[
  0.87, 0.94, 1],ExpressionUUID->"5980b6c8-8111-431e-bd4e-5af33adca5ef"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Finds", " ", "the", " ", "closest", " ", "valid", " ", "CM", " ", "to", 
    " ", "G"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClosestGaussian", "[", "G_", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Lambda]", "=", 
        RowBox[{"Max", "@", 
         RowBox[{"Eigenvalues", "[", 
          RowBox[{
           RowBox[{"\[ImaginaryI]", " ", 
            RowBox[{"J", "[", 
             RowBox[{"Length", "@", "G"}], "]"}]}], "-", "G"}], "]"}]}]}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"G", "+", 
       RowBox[{
        RowBox[{"Max", "@", 
         RowBox[{"{", 
          RowBox[{"0", ",", "\[Lambda]"}], " ", "}"}]}], 
        RowBox[{"IdentityMatrix", "[", 
         RowBox[{"Length", "@", "G"}], "]"}]}]}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Generates", " ", "a", " ", "RQCM"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RQCM", "[", 
     RowBox[{"n_", ",", " ", 
      RowBox[{"\[Sigma]_", ":", "1"}]}], "]"}], ":=", 
    RowBox[{"ClosestGaussian", "[", 
     RowBox[{"G", "[", 
      RowBox[{"n", ",", "\[Sigma]"}], "]"}], "]"}]}]}]}]], "Input",
 CellFrame->True,
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.927963244517919*^9, 3.9279632988279943`*^9}, {
   3.9279641774191113`*^9, 3.927964184003414*^9}, 3.927964322291379*^9, 
   3.941385634649486*^9, 3.941386298485345*^9, {3.9413863298356*^9, 
   3.941386360134748*^9}, {3.941387164442535*^9, 3.9413871664342003`*^9}, {
   3.9413882394969797`*^9, 3.9413882595636873`*^9}, {3.941388572438921*^9, 
   3.941388593973333*^9}, {3.9413888565763197`*^9, 3.941388878571753*^9}, {
   3.94139052992523*^9, 3.941390532990847*^9}, 3.941390958306019*^9, 
   3.9413920662980824`*^9, 3.941393110434623*^9, 3.941393241996586*^9, {
