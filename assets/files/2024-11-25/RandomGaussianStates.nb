Cell["\<\
However, by properly shifting it, we get a valid Gaussian state:\
\>", "Text",
 CellChangeTimes->{{3.9414525882249117`*^9, 
  3.941452598544454*^9}},ExpressionUUID->"bd6c28cd-55e3-46da-93d4-\
07e748ba652c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"H", "=", 
    RowBox[{"ClosestGaussian", "@", 
     SubscriptBox["G", "0"]}]}], ";", 
   RowBox[{"H", "//", "MatrixForm"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Smallest", " ", "eigenvalue", " ", "of", " ", "H"}], " ", "-", 
     " ", 
     SubscriptBox["iJ", 
      RowBox[{"2", "n"}]]}], ",", " ", 
    RowBox[{
     RowBox[{"should", " ", "be", " ", "non"}], "-", "negative"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Chop", "@", 
  RowBox[{"GaussianQ", "@", "H"}]}]}], "Input",
 CellFrame->True,
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.927963244517919*^9, 3.9279632988279943`*^9}, {
