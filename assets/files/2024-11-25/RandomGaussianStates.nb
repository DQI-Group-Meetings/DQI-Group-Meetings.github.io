  "38f5a4d0-d1df-4093-8ed5-ad0e569a1510"],
 "\nThis arises, for example, when one computes the eigenvalues of U A U \
\[ConjugateTranspose] + B, with A and B being diagonal and deterministic and \
U being a CUE element."
}], "Text",
 CellChangeTimes->{{3.9414530102548027`*^9, 3.9414530440754766`*^9}, {
   3.941453106419194*^9, 3.941453190386293*^9}, {3.941453245578179*^9, 
   3.9414536313816833`*^9}, 
   3.941453740261326*^9},ExpressionUUID->"df39535b-709a-427b-afa0-\
edbf12427afb"],

Cell["\<\
One of the useful things we can do with these results is to compute a few \
relevant quantities from the RQCM. For instance, let us consider the purity:\
\>", "Text",
 CellChangeTimes->{{3.941477395051466*^9, 
  3.941477416835484*^9}},ExpressionUUID->"ffc12abe-0ebb-4eb6-909e-\
a5cec26e7728"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[ScriptCapitalP]", "[", "S_", "]"}], ":=", 
   FractionBox["1", 
    SqrtBox[
     RowBox[{"Det", "[", "S", "]"}]]]}], ";"}]], "Input",
 CellFrame->True,
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.927963244517919*^9, 3.9279632988279943`*^9}, {
   3.9279641774191113`*^9, 3.927964184003414*^9}, 3.927964322291379*^9, 
   3.941385634649486*^9, 3.941386298485345*^9, {3.9413863298356*^9, 
   3.941386360134748*^9}, {3.941387164442535*^9, 3.9413871664342003`*^9}, {
   3.9413882394969797`*^9, 3.9413882595636873`*^9}, {3.941388572438921*^9, 
   3.941388593973333*^9}, {3.9413888565763197`*^9, 3.941388878571753*^9}, {
   3.94139052992523*^9, 3.941390532990847*^9}, 3.941390958306019*^9, 
   3.9413920662980824`*^9, 3.941393110434623*^9, 3.941393241996586*^9, {
   3.941451958367324*^9, 3.941451965080182*^9}, {3.941454133334361*^9, 
   3.941454138922277*^9}, {3.941454241968747*^9, 3.941454243274206*^9}},
 Background->GrayLevel[0.95],
 CellLabel->"In[50]:=",ExpressionUUID->"db13f04b-accf-4d9d-b794-142f08d57c09"],

Cell["We compute it for \[Sigma] = 0.5 and \[Sigma] = 2:", "Text",
 CellChangeTimes->{{3.9414774193637543`*^9, 
  3.9414774277318277`*^9}},ExpressionUUID->"759e35e2-5aaf-4656-8c3c-\
85aeafe65b17"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"PurityListA", "=", 
   RowBox[{"\[ScriptCapitalP]", "/@", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"RQCM", "[", 
        RowBox[{"#", ",", " ", "0.5"}], "]"}], "&"}], "/@", 
      RowBox[{"Range", "[", 
       RowBox[{"1", ",", "30"}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PurityListB", "=", 
   RowBox[{"\[ScriptCapitalP]", "/@", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"RQCM", "[", 
        RowBox[{"#", ",", " ", "2"}], "]"}], "&"}], "/@", 
      RowBox[{"Range", "[", 
       RowBox[{"1", ",", "30"}], "]"}]}], ")"}]}]}], ";"}]}], "Input",
 CellFrame->True,
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.927963244517919*^9, 3.9279632988279943`*^9}, {
   3.9279641774191113`*^9, 3.927964184003414*^9}, 3.927964322291379*^9, 
   3.941385634649486*^9, 3.941386298485345*^9, {3.9413863298356*^9, 
   3.941386360134748*^9}, {3.941387164442535*^9, 3.9413871664342003`*^9}, {
   3.9413882394969797`*^9, 3.9413882595636873`*^9}, {3.941388572438921*^9, 
   3.941388593973333*^9}, {3.9413888565763197`*^9, 3.941388878571753*^9}, {
   3.94139052992523*^9, 3.941390532990847*^9}, 3.941390958306019*^9, 
   3.9413920662980824`*^9, 3.941393110434623*^9, 3.941393241996586*^9, {
   3.941451958367324*^9, 3.941451965080182*^9}, {3.941454133334361*^9, 
   3.941454229915649*^9}, {3.941454260309647*^9, 3.941454312603009*^9}, {
   3.941454354893219*^9, 3.941454374009322*^9}},
 Background->GrayLevel[0.95],
 CellLabel->"In[51]:=",ExpressionUUID->"a78fd5ab-15bd-4830-8778-81b65951d850"],

Cell[TextData[{
 StyleBox["Purity of the QRCM:",
  FontWeight->"Bold"],
 " \n\nFor a normalized RQCM(2n, ",
 Cell[BoxData[
  FormBox[
   FractionBox["\[Sigma]", 
    SqrtBox[
     RowBox[{"2", "n"}]]], TraditionalForm]],ExpressionUUID->
  "721b904d-1a11-4935-9331-fe746f4f88d0"],
 "), we can define the quantity:\n\nLD(\[Sigma]) := ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Integral]", 
     RowBox[{
      RowBox[{"R", "(", "\[Sigma]", ")"}], " ", "-", " ", 
      RowBox[{"2", "\[Sigma]"}]}], 
     RowBox[{
      RowBox[{"R", "(", "\[Sigma]", ")"}], " ", "+", " ", 
      RowBox[{"2", "\[Sigma]"}]}]], " ", 
    RowBox[{
     RowBox[{"ln", "(", "x", ")"}], " ", 
     SubscriptBox["dSC", 
      RowBox[{
       RowBox[{"R", "(", "\[Sigma]", ")"}], ",", " ", "\[Sigma]"}]]}]}], 
   TraditionalForm]],ExpressionUUID->"a2f0b914-925c-4655-8037-cd12adeda6b6"],
 "(x);\n\nsuch that, for asymptotic n, we have\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "n"]}], "log", " "}], TraditionalForm]],ExpressionUUID->
  "447f912e-4695-4154-9ba0-21df34c1586d"],
 "\[ScriptCapitalP](S)  \[RightArrow] LD(\[Sigma]). Or, equivalently:\n\n\
\[ScriptCapitalP](S)   ~ ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{
     RowBox[{"-", "n"}], " ", 
     RowBox[{"LD", "(", "\[Sigma]", ")"}], " "}]], TraditionalForm]],
  ExpressionUUID->"4b7200ca-906d-4a06-b79a-5c5a8a6c05bb"]
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellFrameColor->RGBColor[0, 0.67, 0],
 CellChangeTimes->{
  3.896157307770092*^9, {3.8962431518956203`*^9, 3.896243165248736*^9}, {
   3.8962432007660027`*^9, 3.896243215679708*^9}, 3.89624387579119*^9, 
   3.8962479341938753`*^9, 3.896349890244479*^9, {3.896431738204154*^9, 
   3.896431793731579*^9}, {3.896432175643674*^9, 3.896432224386896*^9}, {
   3.898591709469429*^9, 3.8985917097904797`*^9}, {3.89859199556601*^9, 
   3.898591999597328*^9}, {3.898675292731111*^9, 3.898675304034505*^9}, {
   3.898676091306068*^9, 3.898676097371314*^9}, 3.906796741677164*^9, {
   3.941452350484767*^9, 3.941452439319812*^9}, {3.94145363320478*^9, 
   3.94145368303008*^9}, {3.941453733020797*^9, 3.941453799978505*^9}, {
   3.941453851898497*^9, 3.941454052044414*^9}, {3.94147743935413*^9, 
   3.941477444141245*^9}, {3.9414774789577637`*^9, 3.941477721065428*^9}},
 Background->RGBColor[
  0.88, 1, 0.88],ExpressionUUID->"17f9333a-38cd-46b9-9721-1cb11ff85c02"],

Cell["The dashed lines correspond to the analytical prediction:", "Text",
 CellChangeTimes->{{3.9414774193637543`*^9, 3.9414774277318277`*^9}, {
  3.941526675836779*^9, 
  3.941526684572536*^9}},ExpressionUUID->"8534c2ed-61c2-4883-b528-\
0a9b6a9e7290"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LD", "[", "\[Sigma]_", "]"}], ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Log", "[", "x", "]"}], 
     RowBox[{"DSc", "[", 
      RowBox[{"x", ",", "\[Sigma]"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{
       RowBox[{"R", "[", "\[Sigma]", "]"}], "-", 
       RowBox[{"2", "\[Sigma]"}]}], ",", " ", 
      RowBox[{
       RowBox[{"R", "[", "\[Sigma]", "]"}], "+", 
       RowBox[{"2", "\[Sigma]"}]}]}], "}"}]}], "]"}]}]], "Input",
 CellFrame->True,
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.927963244517919*^9, 3.9279632988279943`*^9}, {
   3.9279641774191113`*^9, 3.927964184003414*^9}, 3.927964322291379*^9, 
   3.941385634649486*^9, 3.941386298485345*^9, {3.9413863298356*^9, 
   3.941386360134748*^9}, {3.941387164442535*^9, 3.9413871664342003`*^9}, {
   3.9413882394969797`*^9, 3.9413882595636873`*^9}, {3.941388572438921*^9, 
   3.941388593973333*^9}, {3.9413888565763197`*^9, 3.941388878571753*^9}, {
   3.94139052992523*^9, 3.941390532990847*^9}, 3.941390958306019*^9, 
   3.9413920662980824`*^9, 3.941393110434623*^9, 3.941393241996586*^9, {
   3.941451958367324*^9, 3.941451965080182*^9}, {3.941454133334361*^9, 
   3.941454229915649*^9}, {3.941454260309647*^9, 3.941454312603009*^9}, {
   3.941454354893219*^9, 3.941454374009322*^9}, {3.941476859890664*^9, 
   3.9414768852006397`*^9}},
 Background->GrayLevel[0.95],
 CellLabel->"In[56]:=",ExpressionUUID->"1956a3f0-bd26-44a9-ab8d-82fe0d670c5f"],

