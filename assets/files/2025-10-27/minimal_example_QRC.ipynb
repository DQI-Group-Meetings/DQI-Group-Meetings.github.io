3cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    reservoir_ex = evolution(U_floquet, reservoir_ex, s_input_ex[t])\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    if t \u0026gt; t_washout:\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e        O_1t.append(np.trace(reservoir_ex @ O_1))\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e        O_2t.append(np.trace(reservoir_ex @ O_2))\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e        O_3t.append(np.trace(reservoir_ex @ O_3))\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e","   ]","  },","  {","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;id\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003ebd522515-e0e4-45b0-ad52-d55e12243e43\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {},","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: [","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e---\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e#### ⦿ Example | Plotting the dynamics under the FN protocol\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e","   ]","  },","  {","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;id\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e62dad779-7c5c-427c-a1fb-5e1d794fc800\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {},","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: [","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eWe do this in practice. Let us investigate how the Floquet circuit from the beginning evolves under this protocol. Let us consider that the input data will be something like ${\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ebf s} = (0, 1, 1, 0, 0, \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecdots)$, that is, Bernoulli random variable.\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eTo probe the dynamics, we will consider three observables. Namely:\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;center\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{vec}(\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ePhi(\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003erho_{t-1})) = $\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;img src=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eimages/stroboscopic_example_operators_ZX.svg\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e style=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eheight: 256px\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e align=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ecenter\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/center\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e- The $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003etext{operator } Z_1$ at the left end of the circuit,\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e- another Pauli $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{darkorange} \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003etext{operator } X_1$ to see how the dynamics changes under another operator and\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e- another $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{green} \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003etext{operator } Z_L$ at the opposide end of the lattice to see how spatial/temporal distance from the latest input can be meaningful.\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eThis will tell us how the dynamics of observables correlate with the input data. Basic results are as follows:\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e---\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e","   ]","  },","  {","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003ecode\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;execution_count\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-c1\"\u003e16\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;id\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e0200cd2d-4e05-42c5-b5a8-38f72cf9398d\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {","    \u003cspan class=\"pl-ent\"\u003e\u0026quot;jupyter\u0026quot;\u003c/span\u003e: {","     \u003cspan class=\"pl-ent\"\u003e\u0026quot;source_hidden\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-c1\"\u003etrue\u003c/span\u003e","    }","   },","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;outputs\u0026quot;\u003c/span\u003e: [","    {","     \u003cspan class=\"pl-ent\"\u003e\u0026quot;data\u0026quot;\u003c/span\u003e: {","      \u0026quot;image/png\u0026quot;: \u0026quot;\u0026quot;,","      \u003cspan class=\"pl-ent\"\u003e\u0026quot;text/plain\u0026quot;\u003c/span\u003e: [","       \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;Figure size 640x480 with 1 Axes\u0026gt;\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e","      ]","     },","     \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {},","     \u003cspan class=\"pl-ent\"\u003e\u0026quot;output_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003edisplay_data\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e","    }","   ],","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: [","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e# Rescaled stochastic input for better visualization\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003erescaled_input = (2*s_input_ex[t_washout:] - 1)/3\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.fill_between(list(range(t_max - t_washout)), rescaled_input, alpha=0.1, color=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003egray\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.plot(rescaled_input, color=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eblack\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, linestyle=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003edashed\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, alpha=0.2)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e# Expected values/Features\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.plot(np.real(O_1t), label=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eLeft-end op. $Z_1$\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.plot(np.real(O_2t), label=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eLeft-end op. $X_1$\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.plot(np.real(O_3t), label=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eRight-end op. $Z_L$\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e# Line at zero\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.axhline(y=0, color=\u0026#39;k\u0026#39;, linestyle=\u0026#39;--\u0026#39;, linewidth=1)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.legend(loc=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003elower right\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.xlabel(r\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eTime $t$\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, fontsize=18)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.ylabel(r\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eFeatures $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003elangle O(t) \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003erangle$\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, fontsize=18)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eplt.show()\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e","   ]","  },","  {","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;id\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003ea839cfb3-95a2-4660-a0d8-0c9f3d66f6cb\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {},","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: [","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e### Readout Phase\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eTherefore, in the same spirit of what we just did in the previous example, we extract the output $x_{t,j}$ by computing the expectation value of the observables $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003e{O_j\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003e}$ at time $t$:\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$$\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003eboxed{\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003ex_{t, j} = \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{tr}\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003e{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003erho_t O_j\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003e} \u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e= \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{vec}(O_j)^\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003edagger \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{vec}(\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003erho_t),\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003equad j = 1, \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003edots, M.\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e}\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$$\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eThese quantities form the entries of the **feature matrix**. Graphically, we represent these entries as:\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;center\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$x_{t, j} = \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{tr}\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003e{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003erho_t O_j\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003e}= $\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;img src=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eimages/feature_trace.svg\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e style=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eheight: 160px\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e align=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ecenter\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/center\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;br\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e- Remember that in our example we had $M = 6L - 3$ features, correspond to all single-site and NN Pauli operators.\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;br\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;div class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ehighlight_green\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;div class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003etitle_box\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    \u0026lt;div class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003etitle\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e        ❐ Remarks\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    \u0026lt;/div\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/div\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;div class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003econtent\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eThe Fuji-Nakajima, despite being the first one for QRC, is not unique. We have other viable alternatives, such as:\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    \u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;ul\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;li\u0026gt;\u0026lt;a href=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ehttps://quantum-journal.org/papers/q-2024-03-20-1291/\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;Dissipative approaches\u0026lt;/a\u0026gt;: here, learning power is  harnessed through dissipation in an open quantum system.\u0026lt;/li\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;li\u0026gt;\u0026lt;a href=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ehttps://arxiv.org/abs/2505.22575\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;Hamiltonian-encoding approaches\u0026lt;/a\u0026gt;: we feed the time-series and input data directly into the Hamiltonian itself, rather than into its states.\u0026lt;/li\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/ul\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/div\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/div\u0026gt;\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e","   ]","  },","  {","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;id\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e6130d2d8-bdf8-42b7-8968-4ee0cd715be3\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {},","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: [","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e## 4. Training Phase\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e","   ]","  },","  {","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;id\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e6d1ecc67-ef65-4464-b91a-f263c7e18bd7\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {},","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: [","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;center\u0026gt;\u0026lt;img src=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eimages/time_series_example_diagram_2.svg\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e width = 33%/\u0026gt;\u0026lt;/center\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eOnce the feature matrix is available, we perform **linear optimization** on the training data according to:\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$$\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003edefinecolor{royalred}{rgb}{0.72, 0.11, 0.13}\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalred}y_t} = \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003esum_j w_{t,j} x_{t, j},\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$$\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003ein order to obtain the **weight matrix** ${\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{goldenrod} \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{W}}$. A bias column $x_{t, M + 1} = 1$ is often included in the matrix ${\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ebf X}$. Finally, the easiest training strategy one can emply here is the **[Ridge regression](https://en.wikipedia.org/wiki/Ridge_regression#:~:text=%5B19%5D-,Tikhonov%20regularization,-%5Bedit%5D)** with regularization parameter $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ealpha$, given by:\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$$\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003eboxed{\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003edefinecolor{royalred}{rgb}{0.72, 0.11, 0.13}\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{goldenrod} \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{W}}\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e=\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e(\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} X}^\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathsf{T} \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} X} + \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ealpha \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{I})^{-1}\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} X}^\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathsf{T} \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{y}\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e}.\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$$\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eHere we take $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ealpha = 5 \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003etimes 10^{-3}$.\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e- For a dynamics over $T$ time steps,  $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} X} = \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} X}(\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} s})$ has dimensions $T \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003etimes (M + 1)$\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e- This matrix is determined by the inputs $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{s}$ and the chosen observables/features.\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eOnce the training is performed, we can thus compute the validation data as:\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$$\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalred} y}_{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{val}}\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e=\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{goldenrod} \u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{W}}\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} X}_{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{val}},\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e$$\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003egiven the validation inputs $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} s}_{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{val}}$ and the corresponding feature matrix $\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathbf{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003ecolor{royalblue} X}_{\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{val}}$.\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e","   ]","  },","  {","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;cell_type\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003emarkdown\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;id\u0026quot;\u003c/span\u003e: \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e81951fbb-c063-4e3e-b05e-aba1f1c66255\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;metadata\u0026quot;\u003c/span\u003e: {},","   \u003cspan class=\"pl-ent\"\u003e\u0026quot;source\u0026quot;\u003c/span\u003e: [","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;div class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ehighlight_red\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;div class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003etitle_box\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    \u0026lt;div class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003etitle\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e        ⚠ Note\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    \u0026lt;/div\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;/div\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u0026lt;div class=\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003econtent\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e\u0026gt;\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e- As highlighted in the grayed out portion of the time-series in the picture above, in the RC and QRC protocols one tipically also lets the reservoir undergo the **washout phase**. That is, we discard/risregard any measurements up to time $t_\u003cspan class=\"pl-cce\"\u003e\\\\\u003c/span\u003emathrm{washout}$ so that all dependence on the initial state is dispelled from the dynamics. Only after that the observables/measurements $x_{t, j}$ are taken into account and used to build the feature matrix.\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","    \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e  \u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\